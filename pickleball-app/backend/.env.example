# PostgreSQL connection string used by the app AT RUNTIME.
# For Supabase: use the "Transaction" connection pooler string (port 6543),
# found at Project Settings -> Database -> Connection String -> "Transaction" tab.
# It supports IPv4 and handles many short-lived connections well, which is
# what a web API needs.
DATABASE_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct (non-pooled) connection string, used ONLY for running migrations
# (`prisma migrate dev` / `prisma migrate deploy`). For Supabase: use the
# "Session" pooler string (port 5432) from the same Connection String page —
# NOT the raw db.<project>.supabase.co host, which is IPv6-only on the free
# tier and will fail to connect from most home networks.
DIRECT_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Long random string used to sign JWTs — generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-string"

# Port the API server listens on
PORT=4000

# URL of the frontend, used for CORS
FRONTEND_URL="http://localhost:5173"

NODE_ENV="development"

# Optional: transactional email (Resend) — leave blank to skip email sending in dev
RESEND_API_KEY=""
