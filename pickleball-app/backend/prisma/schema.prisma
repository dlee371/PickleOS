generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  avatarUrl    String?  @map("avatar_url")
  phone        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships       LeagueMembership[]
  createdLeagues    League[]           @relation("LeagueCreatedBy")
  matchesAsPlayer1  Match[]            @relation("MatchPlayer1")
  matchesAsPlayer2  Match[]            @relation("MatchPlayer2")
  submittedScores   Score[]            @relation("ScoreSubmittedBy")
  confirmedScores   Score[]            @relation("ScoreConfirmedBy")

  @@map("users")
}

enum LeagueFormat {
  round_robin
  single_elim
}

model League {
  id                String       @id @default(uuid())
  name              String
  description       String?
  format            LeagueFormat
  joinCode          String       @unique @map("join_code")
  requiresApproval  Boolean      @default(false) @map("requires_approval")
  startDate         DateTime?    @map("start_date") @db.Date
  endDate           DateTime?    @map("end_date") @db.Date
  createdBy         String       @map("created_by")
  createdAt         DateTime     @default(now()) @map("created_at")

  creator      User               @relation("LeagueCreatedBy", fields: [createdBy], references: [id])
  memberships  LeagueMembership[]
  matches      Match[]
  bracketSlots BracketSlot[]

  @@map("leagues")
}

enum MembershipRole {
  admin
  player
}

enum MembershipStatus {
  pending
  active
  removed
}

model LeagueMembership {
  id       String            @id @default(uuid())
  leagueId String            @map("league_id")
  userId   String            @map("user_id")
  role     MembershipRole
  status   MembershipStatus  @default(active)
  joinedAt DateTime          @default(now()) @map("joined_at")

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
  @@map("league_memberships")
}

enum MatchStatus {
  scheduled
  awaiting_confirmation
  completed
  cancelled
}

model Match {
  id           String      @id @default(uuid())
  leagueId     String      @map("league_id")
  round        Int?
  player1Id    String?     @map("player1_id")
  player2Id    String?     @map("player2_id")
  scheduledAt  DateTime?   @map("scheduled_at")
  courtLabel   String?     @map("court_label")
  status       MatchStatus @default(scheduled)
  createdAt    DateTime    @default(now()) @map("created_at")

  league       League        @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  player1      User?         @relation("MatchPlayer1", fields: [player1Id], references: [id])
  player2      User?         @relation("MatchPlayer2", fields: [player2Id], references: [id])
  score        Score?
  bracketSlot  BracketSlot?

  @@map("matches")
}

model Score {
  id             String    @id @default(uuid())
  matchId        String    @unique @map("match_id")
  player1Score   Int       @map("player1_score")
  player2Score   Int       @map("player2_score")
  submittedBy    String    @map("submitted_by")
  confirmedBy    String?   @map("confirmed_by")
  confirmedAt    DateTime? @map("confirmed_at")
  adminOverride  Boolean   @default(false) @map("admin_override")
  createdAt      DateTime  @default(now()) @map("created_at")

  match    Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  submitter User @relation("ScoreSubmittedBy", fields: [submittedBy], references: [id])
  confirmer User? @relation("ScoreConfirmedBy", fields: [confirmedBy], references: [id])

  @@map("scores")
}

model BracketSlot {
  id       String  @id @default(uuid())
  leagueId String  @map("league_id")
  matchId  String? @unique @map("match_id")
  round    Int
  position Int

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  match  Match? @relation(fields: [matchId], references: [id])

  @@unique([leagueId, round, position])
  @@map("bracket_slots")
}
